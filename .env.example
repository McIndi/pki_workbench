# Required sensitive settings
DJANGO_SECRET_KEY=
# Optional for encrypted private key field derivation (comma-separated for key rotation)
DJANGO_FERNET_SALT_KEYS=
# Legacy single-key alias (optional)
DJANGO_SALT_KEY=

# Core Django settings
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_DB_URL=sqlite:///db.sqlite3
DJANGO_LANGUAGE_CODE=en-us
DJANGO_TIME_ZONE=UTC
DJANGO_USE_I18N=True
DJANGO_USE_TZ=True
DJANGO_STATIC_URL=static/
DJANGO_LOGIN_URL=login
DJANGO_LOGIN_REDIRECT_URL=profile
DJANGO_LOGOUT_REDIRECT_URL=login
DJANGO_DEFAULT_AUTO_FIELD=django.db.models.BigAutoField
